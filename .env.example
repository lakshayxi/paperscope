# Copy to .env (gitignored) or export directly in your shell.
# No credentials are required for read access to public venues (guest mode),
# but authenticated access is more reliable and required for some restricted invitations.

# Option A: username + password
OPENREVIEW_USERNAME=your@email.com
OPENREVIEW_PASSWORD=yourpassword

# Option B: a previously-obtained session token, instead of username/password
OPENREVIEW_TOKEN=

# Only needed for `paperscope generate --provider anthropic` (optional, requires the
# `llm` extra). Not needed for fetching, storage, statistics, or evidence commands.
ANTHROPIC_API_KEY=
